# Google Gemini API
GOOGLE_API_KEY=your_google_api_key_here

# YNAB API
YNAB_API_KEY=your_ynab_api_key_here
YNAB_BUDGET_ID=your_budget_id_here
YNAB_ACCOUNT_ID=your_account_id_here

# YNAB Category IDs for utility services
# Find these IDs by running: bun explore-ynab.ts
YNAB_CATEGORY_CLEAN_COMMUNITY_SERVICE=your_category_id_here
YNAB_CATEGORY_STREET_SERVICE=your_category_id_here
YNAB_CATEGORY_DRAINAGE_SERVICE=your_category_id_here
YNAB_CATEGORY_SOLID_WASTE_SERVICES=your_category_id_here
YNAB_CATEGORY_WATER=your_category_id_here
YNAB_CATEGORY_ELECTRIC=your_category_id_here
YNAB_CATEGORY_WASTEWATER=your_category_id_here

# YNAB Reimbursement Category ID
# This is where the roommate's reimbursement is recorded
YNAB_CATEGORY_REIMBURSEMENT=your_reimbursement_category_id_here

# PDF file path
PDF_FILE_PATH=example.pdf

# Mode settings
# Set to "false" to enable Venmo requests, "true" (or unset) for dry-run mode
DRY_RUN=true

# Venmo (only required if DRY_RUN=false)
VENMO_ACCESS_TOKEN=venmo_access_token_here
VENMO_RECIPIENT_USER_ID=venmo_recipient_user_id_here

# COA Utilities
COA_UTILITIES_EMAIL=
COA_UTILITIES_PASSWORD=