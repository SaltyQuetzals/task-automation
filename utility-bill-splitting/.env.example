# Google Gemini API
GOOGLE_API_KEY=your_google_api_key_here

# YNAB API
YNAB_API_KEY=your_ynab_api_key_here
YNAB_BUDGET_ID=your_budget_id_here
YNAB_ACCOUNT_ID=your_account_id_here

# YNAB Category IDs for utility services
# Find these IDs by running: bun find-ynab-categories.ts
YNAB_CLEAN_COMMUNITY_SERVICE_CATEGORY_ID=your_category_id_here
YNAB_STREET_SERVICE_CATEGORY_ID=your_category_id_here
YNAB_DRAINAGE_SERVICE_CATEGORY_ID=your_category_id_here
YNAB_SOLID_WASTE_SERVICES_CATEGORY_ID=your_category_id_here
YNAB_WATER_CATEGORY_ID=your_category_id_here
YNAB_ELECTRIC_CATEGORY_ID=your_category_id_here
YNAB_WASTEWATER_CATEGORY_ID=your_category_id_here
YNAB_REIMBURSEMENT_CATEGORY_ID=your_category_id_here

# PDF file path
PDF_FILE_PATH=example.pdf

# Venmo Configuration (only required if DRY_RUN=false)
VENMO_ACCESS_TOKEN=your_venmo_access_token_here
VENMO_RECIPIENT_USER_ID=your_venmo_recipient_user_id_here

# COA Utilities Credentials
COA_UTILITIES_EMAIL=your_email_here
COA_UTILITIES_PASSWORD=your_password_here